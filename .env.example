COMPOSE_PROJECT_NAME=sistema-barbearia

APP_NAME="Sistema Barbearia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://sistemabarbearia.local
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=debug
AUTH_ACCESS_TOKEN_TTL_MINUTES=10080

# Ajuste este nome para a rede Docker externa real onde ja vivem nginx-proxy, mailpit e mariadb.
DOCKER_SHARED_NETWORK=linehost-network

# Ajuste estes IDs apenas se seu usuario Linux nao for 1000:1000.
APP_UID=1000
APP_GID=1000

VIRTUAL_HOST=sistemabarbearia.local
VIRTUAL_PORT=80
VIRTUAL_PROTO=http

DB_CONNECTION=mysql
DB_DEFAULT_CONNECTION=landlord
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=sistema_barbearia
DB_USERNAME=sistema_barbearia
DB_PASSWORD=secret

LANDLORD_DB_CONNECTION=mysql
LANDLORD_DB_HOST=mariadb
LANDLORD_DB_PORT=3306
LANDLORD_DB_DATABASE=sistema_barbearia_landlord
LANDLORD_DB_USERNAME=sistema_barbearia
LANDLORD_DB_PASSWORD=secret

TENANT_DB_CONNECTION=mysql
TENANT_DB_HOST=mariadb
TENANT_DB_PORT=3306
TENANT_DB_DATABASE=tenant_placeholder
TENANT_DB_USERNAME=sistema_barbearia
TENANT_DB_PASSWORD=secret
TENANT_DATABASE_PREFIX=sistema_barbearia_tenant_
TENANT_DATABASE_CHARSET=utf8mb4
TENANT_DATABASE_COLLATION=utf8mb4_unicode_ci
TENANT_DEFAULT_DOMAIN_SUFFIX=sistemabarbearia.local

CENTRAL_DOMAINS=sistemabarbearia.local,localhost,127.0.0.1
TENANT_SLUG_HEADER=X-Tenant-Slug

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@sistema-barbearia.localhost"
MAIL_FROM_NAME="${APP_NAME}"

QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

OUTBOX_DEFAULT_MAX_ATTEMPTS=5
OUTBOX_DEFAULT_RETRY_BACKOFF_SECONDS=60
OUTBOX_DEFAULT_BATCH_SIZE=50
OUTBOX_RECLAIM_ENABLED=1
OUTBOX_RECLAIM_AUTO_RUN_ON_PROCESS=1
OUTBOX_RECLAIM_STALE_AFTER_SECONDS=300
OUTBOX_RECLAIM_MAX_ATTEMPTS=3
OUTBOX_RECLAIM_BACKOFF_SECONDS=30

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

WHATSAPP_DEFAULT_PROVIDER=fake
WHATSAPP_DEFAULT_TIMEOUT_SECONDS=10
WHATSAPP_ALLOW_PRIVATE_NETWORK_TARGETS=0

STARTUP_TIMEOUT=90
STARTUP_SLEEP=2
WAIT_FOR_DATABASE=1
WAIT_FOR_MAILPIT=0
